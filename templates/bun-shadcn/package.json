{
  "name": "my-project",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot server/main.ts",
    "build": "bun build client/main.tsx --outdir=dist/client --target=browser && bun build server/main.ts --outdir=dist/server --target=bun",
    "build:css": "bun x tailwindcss -i ./client/global.css -o ./dist/client/global.css",
    "start": "NODE_ENV=production bun run dist/server/main.js",
    "typecheck": "tsc"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "@tabler/icons-react": "^3.29.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "bun-types": "^1.3.2",
    "typescript": "^5.9.2",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.5.6",
    "autoprefixer": "^10.4.21"
  }
}
